# eBay Developer API credentials (get from developer.ebay.com)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_ENVIRONMENT=production  # or 'sandbox'

# Shipping settings
SHIPPING_RATE_PER_KG=9.00
DEFAULT_WEIGHT_KG=0.5

# VAT settings
VAT_ENABLED=false
VAT_RATE=0.18

# Database
DATABASE_URL=sqlite+aiosqlite:///./ebay_arbitrage.db

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
